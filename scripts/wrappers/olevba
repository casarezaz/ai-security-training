#!/usr/bin/env bash
# Wrapper: runs olevba inside the security Docker container
# Usage: ./scripts/wrappers/olevba [args...]
CONTAINER="aiml-sectools"
if ! docker ps --format '{{.Names}}' | grep -q "^$CONTAINER$"; then
    echo "Starting security container..."
    cd "$HOME/aiml-cybersecurity/docker" && docker compose up -d sectools
fi
docker exec -it $CONTAINER olevba  "$@"
